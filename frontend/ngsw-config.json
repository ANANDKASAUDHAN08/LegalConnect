{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/media/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "legal-api",
      "urls": [
        "http://localhost:5000/api/legal/**",
        "http://localhost:5000/api/lawyers/**"
      ],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "7d",
        "timeout": "5s",
        "strategy": "performance"
      }
    },
    {
      "name": "auth-api",
      "urls": [
        "http://localhost:5001/api/auth/me"
      ],
      "cacheConfig": {
        "maxSize": 1,
        "maxAge": "1d",
        "timeout": "10s",
        "strategy": "freshness"
      }
    }
  ]
}
